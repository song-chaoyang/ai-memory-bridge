{
  "name": "ai-memory-bridge",
  "version": "1.0.0",
  "description": "🌉 跨AI平台记忆迁移工具 | Universal AI Memory Bridge - Export, transform, and import your AI conversations across platforms",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aimb": "dist/cli/index.js",
    "ai-memory-bridge": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint"
  },
  "keywords": [
    "ai",
    "memory",
    "export",
    "import",
    "chatgpt",
    "claude",
    "openai",
    "anthropic",
    "conversation",
    "backup",
    "migration",
    "universal",
    "bridge",
    "cross-platform",
    "llm",
    "chat-history"
  ],
  "author": "AI Memory Bridge Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/songchaoyang/ai-memory-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/songchaoyang/ai-memory-bridge/issues"
  },
  "homepage": "https://github.com/songchaoyang/ai-memory-bridge#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "inquirer": "^8.2.6",
    "fs-extra": "^11.1.1",
    "js-yaml": "^4.1.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/uuid": "^9.0.6",
    "@types/inquirer": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "prettier": "^3.0.3"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ]
}
